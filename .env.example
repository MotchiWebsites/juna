DJANGO_SECRET_KEY=replace-this-with-a-long-random-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000
DJANGO_TIME_ZONE=America/Toronto
DJANGO_LOG_LEVEL=INFO
# Production HTTPS policy. Vercel automatically provisions HTTPS for the site.
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True

# Public site origin used by canonical, crawler, and social metadata.
SITE_URL=http://127.0.0.1:8000

# Database configuration - Neon
NEON_BRANCH=
DATABASE_URL=
DATABASE_URL_UNPOOLED=
