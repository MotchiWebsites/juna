DJANGO_SECRET_KEY=replace-this-with-a-long-random-secret
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,juna.motchi.ca
DJANGO_CSRF_TRUSTED_ORIGINS=https://juna.motchi.ca
DJANGO_TIME_ZONE=America/Toronto
# Start low, then increase after confirming HTTPS works everywhere.
DJANGO_SECURE_HSTS_SECONDS=3600
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False

# Public production origin, without a trailing slash.
SITE_URL=https://your-real-domain.com

# Database configuration - Neon
NEON_BRANCH=
DATABASE_URL=
DATABASE_URL_UNPOOLED=
