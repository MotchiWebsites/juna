{
  "name": "juna",
  "version": "1.0.0",
  "private": true,
  "description": "Frontend asset pipeline for the Juna website",
  "scripts": {
    "predev": "npm run copy:htmx",
    "dev": "concurrently --kill-others-on-fail --names tailwind,django \"npm:dev:css\" \"npm:dev:django\"",
    "dev:css": "tailwindcss -i ./static/src/app.css -o ./static/css/app.css --watch",
    "dev:django": ".venv/bin/python manage.py runserver",
    "build:css": "tailwindcss -i ./static/src/app.css -o ./static/css/app.css --minify",
    "copy:htmx": "mkdir -p static/vendor && cp node_modules/htmx.org/dist/htmx.min.js static/vendor/htmx.min.js",
    "build": "npm run copy:htmx && npm run build:css"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MotchiWebsites/juna.git"
  },
  "license": "GPL-3.0-only",
  "type": "commonjs",
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10"
  },
  "bugs": {
    "url": "https://github.com/MotchiWebsites/juna/issues"
  },
  "homepage": "https://github.com/MotchiWebsites/juna#readme",
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "concurrently": "^10.0.3",
    "htmx.org": "^2.0.10",
    "tailwindcss": "^4.3.2"
  }
}
