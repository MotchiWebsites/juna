{
  "name": "juna",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev:css": "npx @tailwindcss/cli -i ./static/src/app.css -o ./static/css/app.css --watch",
    "build:css": "npx @tailwindcss/cli -i ./static/src/app.css -o ./static/css/app.css --minify",
    "copy:htmx": "mkdir -p static/vendor && cp node_modules/htmx.org/dist/htmx.min.js static/vendor/htmx.min.js",
    "dev": "npm run copy:htmx && npm run dev:css",
    "build": "npm run copy:htmx && npm run build:css"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MotchiWebsites/juna.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/MotchiWebsites/juna/issues"
  },
  "homepage": "https://github.com/MotchiWebsites/juna#readme",
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "tailwindcss": "^4.3.2",
    "htmx.org": "^2.0.10"
  }
}